# CampaignX API Configuration
# Copy this file to .env and fill in your values

# API Base URL
CAMPAIGNX_API_BASE_URL=https://campaignx.inxiteout.ai

# API Key (get this from signup endpoint - shown only once)
CAMPAIGNX_API_KEY=your_api_key_here

# Team Info (for initial signup)
CAMPAIGNX_TEAM_NAME=your_team_name
CAMPAIGNX_TEAM_EMAIL=your_team_email@example.com
